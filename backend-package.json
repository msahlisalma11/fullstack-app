{
  "name": "greenbite-backend",
  "version": "1.0.0",
  "description": "GreenBite TN - Backend API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "migrate": "node -r ts-node/register src/migrations/run.ts",
    "seed": "ts-node src/seeds/index.ts",
    "test": "jest",
    "lint": "eslint src --ext .ts"
  },
  "keywords": ["greenbite", "food-waste", "marketplace"],
  "author": "GreenBite Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "typescript": "^5.0.0",
    "pg": "^8.10.0",
    "dotenv": "^16.0.3",
    "jsonwebtoken": "^9.0.0",
    "bcrypt": "^5.1.0",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "express-validator": "^7.0.0",
    "stripe": "^12.0.0",
    "node-qrcode": "^1.5.3",
    "socket.io": "^4.6.0",
    "socket.io-client": "^4.6.0",
    "multer": "^1.4.5-lts.1",
    "cloudinary": "^1.35.0",
    "nodemailer": "^6.9.1",
    "pino": "^8.12.0",
    "pino-http": "^8.3.3",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.10.0",
    "@types/bcrypt": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/jest": "^29.5.0",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "eslint": "^8.40.0",
    "@typescript-eslint/eslint-plugin": "^5.59.0",
    "@typescript-eslint/parser": "^5.59.0"
  }
}
